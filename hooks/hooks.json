{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/auto_approve.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/translate_notification.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
